+import { useEffect, useState } from "react";
+import { Loader2 } from "lucide-react";
+import { reportingApi, type EmployeeKpiRow } from "@/lib/reporting.api";
+import { EmployeeKpiTable } from "../dashboard/EmployeeKpiTable";
