+      ),
+    );
+  const pendingByTransactionId = new Map(pendingRequests.map((r) => [r.commissionTransactionId, r.id]));
+
+  return views.map((v) => ({ ...v, pendingEditRequestId: pendingByTransactionId.get(v.id) }));
 }
 
