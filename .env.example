# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
DB_USER=prestix_user
DB_PASSWORD=changeme
DB_NAME=prestix_db
DATABASE_URL=postgres://prestix_user:changeme@postgres:5432/prestix_db

# Auth
JWT_SECRET=changeme_use_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_IN_MINUTES=15
OTP_MAX_ATTEMPTS=5

# Email / SMTP
# Gmail test account: enable 2-Step Verification, create an App Password, use it as SMTP_PASS.
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=GOOGLE_APP_PASSWORD_WITHOUT_SPACES
MAIL_FROM=PrestiX <your.email@gmail.com>

# Financial params (Sprint 1 settings row)
EPARGNE_INSCRIPTION_FEE=5000
PENALTY_AMOUNT_XAF=2500
CREDIT_DECISION_WINDOW_DAYS=30
