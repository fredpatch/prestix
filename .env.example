# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
DB_USER=prestix_user
DB_PASSWORD=changeme
DB_NAME=prestix_db
DATABASE_URL=postgres://prestix_user:changeme@postgres:5432/prestix_db

# Auth
JWT_SECRET=changeme_use_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_IN_MINUTES=15
OTP_MAX_ATTEMPTS=5

# Email / SMTP
SMTP_HOST=smtp.domain.com
SMTP_PORT=587
SMTP_USER=noreply@domain.com
SMTP_PASSWORD=changeme
SMTP_FROM=noreply@domain.com

# Financial params (Sprint 1 settings row)
EPARGNE_INSCRIPTION_FEE=5000
PENALTY_AMOUNT_XAF=2500
CREDIT_DECISION_WINDOW_DAYS=30
