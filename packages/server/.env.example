# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://prestix_user:changeme@localhost:5432/prestix_db

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_MINIMUM_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_IN_PRODUCTION_MINIMUM_32_CHARS_REFRESH
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── OTP ────────────────────────────────────────────────────
OTP_EXPIRES_IN_MINUTES=15
OTP_MAX_ATTEMPTS=5

# ── SMTP ───────────────────────────────────────────────────
MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=GOOGLE_APP_PASSWORD_WITHOUT_SPACES
MAIL_FROM=PrestiX <your.email@gmail.com>

# ── Security ───────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
LOCKOUT_MAX_ATTEMPTS=5

# ── Financial params (Sprint 1 settings row) ────────────────
EPARGNE_INSCRIPTION_FEE=5000
PENALTY_AMOUNT_XAF=2500
CREDIT_DECISION_WINDOW_DAYS=30
